<ui:FluentWindow x:Class="LocalScribe.App.ReadViewWindow" x:Name="Self"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LocalScribe.App"
        xmlns:vm="clr-namespace:LocalScribe.App.ViewModels"
        Title="{Binding Title}" Height="560" Width="720" MinHeight="300" MinWidth="420"
        WindowBackdropType="None" ExtendsContentIntoTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ReadViewStampConverter x:Key="Stamp" />
        <!-- The row context menu is declared inside a ListViewItem Style.Setter, so its runtime
             DataContext is the ReadRow, and (unlike a direct child) the XAML compiler does NOT wire
             Click="..." handlers on menu items nested there. Route to the window's commands instead
             (same fix SessionsPage uses via VmProxy). Data is set to the window in the code-behind
             ctor, so Data.<Command> reaches the ReadViewWindow's own commands; CommandParameter
             stays the local ReadRow. -->
        <local:BindingProxy x:Key="WindowProxy" />
    </Window.Resources>
    <!-- Display controls plus Stage 6.1's two edit affordances: the row context menu opens the
         Correct text / Reassign speaker dialogs; everything else remains read-only. -->
    <DockPanel TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <ui:TitleBar DockPanel.Dock="Top" Title="{Binding Title}"
                     ShowMinimize="True" ShowMaximize="True" ShowClose="True" />
        <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding DateDisplay}" Margin="0,0,12,0" />
                <TextBlock Text="{Binding DurationDisplay}" Margin="0,0,12,0" />
                <TextBlock Text="Recovered" Style="{StaticResource WarningText}" Margin="0,0,8,0"
                           ToolTip="Recovered after an interruption; duration is transcript-derived, not wall-clock"
                           Visibility="{Binding Recovered, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="Edited" Style="{StaticResource WarningText}" Margin="0,0,8,0"
                           Visibility="{Binding Edited, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="System mix" Style="{StaticResource WarningText}" Margin="0,0,8,0"
                           ToolTip="Remote audio came from the system-wide mix; other apps' audio may be present"
                           Visibility="{Binding SystemMix, Converter={StaticResource BoolToVis}}" />
                <Button Content="Split speakers..." Click="OnSplitSpeakers"
                        IsEnabled="{Binding CanDiarise}"
                        Visibility="{Binding CanDiarise, Converter={StaticResource BoolToVis}}" />
                <!-- Task 14: Edit-mode toggle. These are direct (un-templated) header children, so
                     a plain Command binding via ElementName=Self reaches the window's own commands
                     (the window's DataContext is the VM, not the window itself) - no WindowProxy
                     needed here (that's reserved for controls declared inside a Style/DataTemplate,
                     e.g. the row ContextMenu below). Edit needs BOTH "not already editing" AND
                     "session is editable"; WPF has no built-in AND-of-two-bools converter and this
                     project has none of its own, so a MultiDataTrigger drives its own Visibility
                     (same house fallback ReassignSpeakerDialog.xaml uses for a single inverse bool). -->
                <Button Content="Edit" Margin="0,0,8,0"
                        Command="{Binding EnterEditCommand, ElementName=Self}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEditMode}" Value="False" />
                                        <Condition Binding="{Binding CanEdit}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Save" Margin="0,0,8,0"
                        Command="{Binding SaveEditsCommand, ElementName=Self}"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
                <Button Content="Cancel"
                        Command="{Binding CancelEditCommand, ElementName=Self}"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding MatterDisplays}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Mode=OneWay}" Opacity="0.8" Margin="0,0,8,0" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding ParticipantDisplays}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Mode=OneWay}" Opacity="0.8" Margin="0,0,8,0" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="System-audio mix was active for part of this session (degraded capture marker present)."
                       Style="{StaticResource WarningText}"
                       Visibility="{Binding HasDegradedMarker, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0"
                Visibility="{Binding Playback.IsAvailable, Converter={StaticResource BoolToVis}}">
            <!-- WrapPanel (not a non-wrapping StackPanel) so the control clusters below wrap to a
                 second row instead of clipping off the window edge when narrowed. Each logical
                 control (buttons; elapsed+seek+total; the mute toggles; each vol label+slider)
                 wraps as its own unit via an inner horizontal StackPanel, since the fixed-width
                 SeekSlider can't gracefully share a wrap line with everything else. -->
            <WrapPanel Orientation="Horizontal">
                <Button Content="{Binding Playback.PlayPauseCaption}"
                        Command="{Binding Playback.PlayPauseCommand}" Margin="0,0,12,4" />
                <Button Content="Stop" Command="{Binding Playback.StopCommand}" Margin="0,0,12,4"
                        ToolTip="Stop and rewind to the start" />
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <TextBlock Text="{Binding Playback.PositionDisplay}" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <!-- TwoWay on SliderValueMs (NOT PositionMs): Slider's own class handlers mark
                         track-click and arrow/Page/Home/End KeyDown Handled BEFORE any XAML instance
                         handler runs, so Preview*/KeyDown wiring here could never see those gestures.
                         The TwoWay binding fires for every WPF-side Value change regardless, and
                         PlaybackViewModel.OnSliderValueMsChanged commits the seek (Stage 5.4 smoke-fix). -->
                    <Slider x:Name="SeekSlider" Width="240" Minimum="0" VerticalAlignment="Center" Margin="0,0,4,0"
                            IsMoveToPointEnabled="True"
                            Maximum="{Binding Playback.DurationMs}"
                            Value="{Binding Playback.SliderValueMs, Mode=TwoWay}"
                            SmallChange="5000" LargeChange="30000"
                            Thumb.DragStarted="OnSeekDragStarted" Thumb.DragCompleted="OnSeekDragCompleted" />
                    <TextBlock Text="{Binding Playback.DurationDisplay}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <ToggleButton Content="Mute local" IsChecked="{Binding Playback.LocalMuted}" Margin="0,0,4,0"
                                  ToolTip="Silence the local (my microphone) leg"
                                  Visibility="{Binding Playback.HasLocalLeg, Converter={StaticResource BoolToVis}}" />
                    <ToggleButton Content="Mute remote" IsChecked="{Binding Playback.RemoteMuted}"
                                  ToolTip="Silence the remote (other party) leg"
                                  Visibility="{Binding Playback.HasRemoteLeg, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                            Visibility="{Binding Playback.HasLocalLeg, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Local vol" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Slider Width="80" Minimum="0" Maximum="1" VerticalAlignment="Center"
                            Value="{Binding Playback.LocalVolume}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                            Visibility="{Binding Playback.HasRemoteLeg, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Remote vol" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Slider Width="80" Minimum="0" Maximum="1" VerticalAlignment="Center"
                            Value="{Binding Playback.RemoteVolume}" />
                </StackPanel>
            </WrapPanel>
        </Border>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding ModelBackendFooter}" Opacity="0.6" Margin="0,8,0,0" />
        <!-- The "now playing" highlight lives on each row's IsNowPlaying flag (ItemContainerStyle
             trigger below), NOT SelectedIndex: binding the highlight to selection meant the VM
             and the user's own click wrote the same property, silently discarding a real
             selection every ~150ms tick, and fired a UIA selection-changed announcement on every
             section advance. MouseDoubleClick still reads RowList.SelectedIndex in the code-behind
             for genuine user activation, now unpolluted by playback. -->
        <!-- Task 14: read list and edit list occupy the same Grid cell (DockPanel.LastChildFill),
             toggled by IsEditMode - only one is ever visible, so there is no layout overlap despite
             sharing the cell. RowList has no built-in inverse-bool converter to hide it on
             IsEditMode=True, so it falls back to the same Style+DataTrigger pattern
             ReassignSpeakerDialog.xaml already uses for a single inverse bool. -->
        <Grid>
        <ListView x:Name="RowList" ItemsSource="{Binding Rows}"
                  MouseDoubleClick="OnRowActivated"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True">
            <ListView.Style>
                <Style TargetType="ListView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <EventSetter Event="ContextMenuOpening" Handler="OnRowContextMenuOpening" />
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Correct text..."
                                          Command="{Binding Data.CorrectTextCommand, Source={StaticResource WindowProxy}}"
                                          CommandParameter="{Binding}"
                                          IsEnabled="{Binding HasSegments}" />
                                <MenuItem Header="Reassign speaker..."
                                          Command="{Binding Data.ReassignSpeakerCommand, Source={StaticResource WindowProxy}}"
                                          CommandParameter="{Binding}"
                                          IsEnabled="{Binding HasSegments}" />
                                <Separator />
                                <MenuItem Header="Remove speaker pin..."
                                          Command="{Binding Data.RemovePinCommand, Source={StaticResource WindowProxy}}"
                                          CommandParameter="{Binding}"
                                          IsEnabled="{Binding HasPin}" />
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <!-- Same pale accent tint as SessionsPage.xaml's selected-row style, applied
                             to a data-bound flag instead of IsSelected. -->
                        <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource SystemAccentColor}" Opacity="0.28" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontWeight="SemiBold" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Data.IsMarker}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding Data.StartMs, Mode=OneWay, Converter={StaticResource Stamp}, StringFormat='[{0}]'}" />
                            <Run Text="{Binding Data.DisplayName, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Text=" (edited)" FontStyle="Italic" Opacity="0.7"
                                   ToolTip="Contains corrected text; the machine original is preserved"
                                   Visibility="{Binding Data.HasCorrection, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                        <TextBlock Text="{Binding Data.Text, Mode=OneWay}" TextWrapping="Wrap" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Data.IsMarker}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!-- Edit-mode table: one row per EditableSectionViewModel, collapsed (read-only Speaker |
             Time | Text) until clicked, then expanded (DataTrigger on IsEditing) into its
             segments. Virtualized the same way RowList is - all edit state lives on the VMs
             (EditableSectionViewModel/EditableSegmentViewModel), so container recycling across a
             data-triggered template is safe (nothing is cached on the visual tree). -->
        <ListView x:Name="EditList" ItemsSource="{Binding EditSections}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:EditableSectionViewModel}">
                    <Grid>
                        <!-- Collapsed: read-only Speaker | Time | Text. A click activates
                             BeginEdit via code-behind (needs TimestampsMode/StartedAtLocal from
                             the window/VM, which is why this is not a pure command). -->
                        <StackPanel x:Name="CollapsedPanel" Background="Transparent"
                                    MouseLeftButtonUp="OnEditRowActivated" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Row.DisplayName, Mode=OneWay}" />
                                <TextBlock Opacity="0.7" Margin="6,0,0,0"
                                           Text="{Binding Row.StartMs, Mode=OneWay, Converter={StaticResource Stamp}, StringFormat='[{0}]'}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Row.Text, Mode=OneWay}" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                        <!-- Expanded: one sub-row per segment. Speaker/time are placeholders here
                             (Tasks 15/16 replace them with a ComboBox and an editable time field);
                             the point of this task is the toggle + expand + Enter-to-split. -->
                        <ItemsControl x:Name="ExpandedPanel" ItemsSource="{Binding Segments}" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:EditableSegmentViewModel}">
                                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="0,4,0,4" Margin="0,0,0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding Source, Mode=OneWay}" MinWidth="70" Opacity="0.8" />
                                                <TextBlock Opacity="0.7" Margin="8,0,0,0"
                                                           Text="{Binding StartMs, Mode=OneWay, Converter={StaticResource Stamp}}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding EditedText, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="False" TextWrapping="Wrap"
                                                     PreviewKeyDown="OnSegmentTextBoxPreviewKeyDown" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter TargetName="CollapsedPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ExpandedPanel" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>
        </DockPanel>
    </DockPanel>
</ui:FluentWindow>
