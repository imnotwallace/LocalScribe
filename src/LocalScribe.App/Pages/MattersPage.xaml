<Page x:Class="LocalScribe.App.Pages.MattersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Matters">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>
    <Grid Margin="12" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <ui:TextBox Width="180" Margin="0,0,8,8" VerticalAlignment="Center"
                            PlaceholderText="New matter name"
                            Text="{Binding NewMatterName, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Content="New matter" Appearance="Primary" Margin="0,0,0,8" Click="OnCreateMatter" />
            </WrapPanel>
            <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <!-- Stage 5.4 5.3: search filters the list below by name, reference, or id,
                     composing with Show archived. -->
                <ui:TextBox Width="180" Margin="0,0,12,8" VerticalAlignment="Center"
                            PlaceholderText="Search matters..."
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Content="Show archived" IsChecked="{Binding ShowArchived}"
                          VerticalAlignment="Center" Margin="0,0,12,8" />
            </WrapPanel>
            <ListView x:Name="MatterList" ItemsSource="{Binding Matters}"
                      SelectionChanged="OnMatterSelected"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name, Mode=OneWay}" Margin="0,0,8,0" />
                                <TextBlock Text="archived" FontSize="11" Style="{StaticResource WarningText}" VerticalAlignment="Center"
                                           Visibility="{Binding Archived, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <TextBlock FontSize="11" Opacity="0.7">
                                <Run Text="{Binding Id, Mode=OneWay}" />
                                <Run Text="{Binding Reference, Mode=OneWay}" />
                                <Run Text="{Binding SessionCount, Mode=OneWay, StringFormat='{}{0} session(s)'}" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>

        <ScrollViewer Grid.Column="1"
                      Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <ui:Card Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Details" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Name" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 LostFocus="OnDetailCommit" Margin="0,0,0,8" />
                        <TextBlock Text="Reference" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EditReference, UpdateSourceTrigger=PropertyChanged}"
                                 LostFocus="OnDetailCommit" Margin="0,0,0,8" />
                        <TextBlock Text="Description" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 LostFocus="OnDetailCommit" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="60" Margin="0,0,0,8" />
                        <CheckBox Content="Archived" IsChecked="{Binding EditArchived}"
                                  Click="OnDetailCommit" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CascadeStatus}" Style="{StaticResource WarningText}" Margin="0,0,0,8" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Roster" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Roster}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBox Width="180" Text="{Binding Name, Mode=OneWay}" Tag="{Binding Id}"
                                                 LostFocus="OnMemberRename" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Role, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ui:Button Content="Remove" Appearance="Secondary" Tag="{Binding Id}" Click="OnMemberRemove" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ui:TextBox Width="140" PlaceholderText="Name" Margin="0,0,8,8"
                                        Text="{Binding NewMemberName, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:TextBox Width="100" PlaceholderText="Role" Margin="0,0,8,8"
                                        Text="{Binding NewMemberRole, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Content="Add member" Appearance="Primary" Margin="0,0,0,8" Click="OnAddMember" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Custom vocabulary" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource Note}" TextWrapping="Wrap"
                                   Text="Terms and corrections scoped to this matter (client names, case jargon). They add to the global vocabulary; a matter correction overrides a same-word global one. New recordings tagged with this matter get the term bias; already-recorded sessions update only when you re-render them below." />

                        <TextBlock Text="Terms" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <ItemsControl ItemsSource="{Binding Vocabulary.Terms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="{Binding Text}" VerticalAlignment="Center" MinWidth="220" />
                                        <Button Content="Remove"
                                                Command="{Binding DataContext.Vocabulary.RemoveTermCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox MinWidth="220"
                                     Text="{Binding Vocabulary.NewTerm, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Add" Margin="8,0,0,0"
                                    Command="{Binding Vocabulary.AddTermCommand}" />
                        </StackPanel>

                        <TextBlock Text="Corrections (heard -&gt; correct)" FontWeight="SemiBold" Margin="0,12,0,4" />
                        <ItemsControl ItemsSource="{Binding Vocabulary.Corrections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="{Binding Heard}" VerticalAlignment="Center" MinWidth="120" />
                                        <TextBlock Text="-&gt;" VerticalAlignment="Center" Margin="4,0" />
                                        <TextBlock Text="{Binding Correct}" VerticalAlignment="Center" MinWidth="120" />
                                        <Button Content="Remove" Margin="8,0,0,0"
                                                Command="{Binding DataContext.Vocabulary.RemoveCorrectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox MinWidth="120"
                                     Text="{Binding Vocabulary.NewHeard, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox MinWidth="120" Margin="8,0,0,0"
                                     Text="{Binding Vocabulary.NewCorrect, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Add" Margin="8,0,0,0"
                                    Command="{Binding Vocabulary.AddCorrectionCommand}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <ui:Button Content="Re-render tagged sessions" Click="OnRerenderTagged" />
                            <TextBlock Text="{Binding CascadeStatus}" Style="{StaticResource WarningText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Tagged sessions" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding TaggedSessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding Title, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding DateDisplay, Mode=OneWay}" Opacity="0.7"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ui:Button Content="Open" Appearance="Secondary" Tag="{Binding SessionId}"
                                                   Click="OnJumpToSession" Margin="0,0,8,0" />
                                        <ui:Button Content="Untag" Appearance="Secondary" Tag="{Binding SessionId}"
                                                   Click="OnUntagSession" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <ui:Card Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Advanced" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ui:Button Content="Repair index" Appearance="Secondary" HorizontalAlignment="Left"
                                   ToolTip="Rebuilds the matter-to-session index if the list looks out of date."
                                   Click="OnRepairIndex" />
                    </StackPanel>
                </ui:Card>

                <ui:Button Content="Export matter archive..." Appearance="Secondary" Click="OnExportMatter"
                           HorizontalAlignment="Left" Margin="0,4,0,0"
                           ToolTip="Bundles this matter's tagged sessions (and a matter.json snapshot) into one .zip." />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                            Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="200" Minimum="0" Maximum="{Binding ExportMax}" Value="{Binding ExportProgress}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ui:Button Content="Cancel" Appearance="Secondary" Click="OnCancelExport" />
                </StackPanel>

                <ui:Button Content="Delete matter" Appearance="Secondary" Click="OnDeleteMatter"
                           HorizontalAlignment="Left" Margin="0,4,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
