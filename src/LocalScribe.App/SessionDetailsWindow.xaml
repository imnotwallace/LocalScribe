<ui:FluentWindow x:Class="LocalScribe.App.SessionDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:LocalScribe.App.ViewModels"
        Title="Session details" Height="640" Width="460" MinHeight="400" MinWidth="380"
        Icon="pack://application:,,,/Assets/LocalScribe.ico"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="Session details"
                     ShowMinimize="True" ShowMaximize="True" ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/LocalScribe.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <ScrollViewer x:Name="DetailPane" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- Lifted verbatim (minus the drawer's close button) from the interim drawer in
                     Pages/SessionsPage.xaml (design 3.3) - this window IS the detail view, so there
                     is no card-visibility trigger and no close affordance beyond the title bar. -->
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Text="Saved" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Visibility="{Binding SavedIndicator, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="Details" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                </DockPanel>
                <TextBlock Text="{Binding LockHint}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />

                <StackPanel IsEnabled="{Binding IsEditable}">
                    <!-- Session -->
                    <ui:Card Style="{StaticResource SectionCard}" Margin="0,8,0,12">
                        <StackPanel>
                            <TextBlock Text="Session" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="Title" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock Text="Description" Margin="0,12,0,4" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" MinLines="3" TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Classification -->
                    <ui:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Classification" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="Call type" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{x:Static vm:MetadataEditorViewModel.MediumOptions}"
                                      DisplayMemberPath="Display" SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedMedium}" />
                            <DockPanel Margin="0,12,0,4">
                                <CheckBox DockPanel.Dock="Right" Content="Show archived"
                                          IsChecked="{Binding ShowArchivedMatters}" />
                                <TextBlock Text="Matters" />
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding MatterOptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Display}" IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                  Command="{Binding DataContext.ToggleMatterCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>

                    <!-- Participants -->
                    <ui:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Participants" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding Participants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2,0,2">
                                            <ui:Button DockPanel.Dock="Right" Content="Remove" Appearance="Secondary"
                                                       Command="{Binding DataContext.RemoveParticipantCommand,
                                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}" />
                                                <Run Text="{Binding SideDisplay, Mode=OneWay}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <Run Text="{Binding Role, Mode=OneWay}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add existing roster person -->
                            <TextBlock Text="Add from roster" Margin="0,12,0,4" Style="{StaticResource MutedText}" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="Add" Appearance="Primary"
                                           Command="{Binding AddFromRosterCommand}" Margin="8,0,0,0" />
                                <ComboBox ItemsSource="{Binding RosterPicks}" DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedRosterPick}" />
                            </DockPanel>

                            <!-- Add a new person by name -->
                            <TextBlock Text="Add a new person" Margin="0,12,0,4" Style="{StaticResource MutedText}" />
                            <ui:TextBox PlaceholderText="Name"
                                        Text="{Binding NewParticipantName, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="They are a remote participant" Margin="0,6,0,0"
                                      IsChecked="{Binding NewParticipantIsRemote}" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ui:Button Content="Add to this session" Appearance="Secondary"
                                           Command="{Binding AddFreeTextCommand}" Margin="0,0,8,0" />
                                <ui:Button Content="Add to session + roster" Appearance="Primary"
                                           Command="{Binding AddToRosterAndSessionCommand}" />
                            </StackPanel>
                            <DockPanel Margin="0,8,0,0">
                                <ComboBox DockPanel.Dock="Right" MinWidth="160"
                                          ItemsSource="{Binding TaggedMatters}" DisplayMemberPath="Display"
                                          SelectedValuePath="Id" SelectedValue="{Binding RosterTargetMatterId}" />
                                <TextBlock Text="Save new people to matter:" VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- Speakers -->
                    <ui:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Speakers" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="Local speakers" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding LocalCount, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <TextBlock Text="Remote speakers" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding RemoteCount, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                            </UniformGrid>
                            <CheckBox Content="Archived (hidden from the default list)"
                                      IsChecked="{Binding Archived}" Margin="0,12,0,0" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</ui:FluentWindow>
