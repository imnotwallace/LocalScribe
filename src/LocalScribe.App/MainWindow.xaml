<ui:FluentWindow x:Class="LocalScribe.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:LocalScribe.App.Pages"
        Title="LocalScribe" Height="720" Width="1080" MinHeight="480" MinWidth="960"
        Icon="pack://application:,,,/Assets/LocalScribe.ico"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True">
    <DockPanel TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <ui:TitleBar x:Name="TitleBar" DockPanel.Dock="Top" Title="LocalScribe"
                     ShowMinimize="True" ShowMaximize="True" ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/LocalScribe.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <ui:InfoBar x:Name="ErrorBar" DockPanel.Dock="Top" Margin="12,12,12,0"
                    Title="LocalScribe" Severity="Error" IsClosable="True" IsOpen="False" />
        <Border DockPanel.Dock="Bottom" Padding="12,6" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Session.State}" Value="Recording">
                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Session.State}" Value="Paused">
                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding Session.State}" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding Session.Elapsed}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Session.IsIdle}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
        <!-- PaneDisplayMode="Left" gives a true CompactPaneLength (48px) icons-only rail when the
             pane is closed; the hamburger expands it to the OpenPaneLength (200px) labelled pane.
             LeftFluent (the prior fallback) instead rendered a ~200px icon+label pane even when
             "closed", which never collapsed and ate the content width. -->
        <ui:NavigationView x:Name="RootNav" PaneDisplayMode="Left" OpenPaneLength="200"
                           CompactPaneLength="48" IsBackButtonVisible="Collapsed" IsPaneToggleVisible="True"
                           IsPaneOpen="False"
                           SelectionChanged="OnNavSelectionChanged">
            <ui:NavigationView.MenuItems>
                <!-- Record is a COMMAND, not a section - no TargetPageType. Clicking it OPENS the
                     Record console (idle "Ready to record" when not capturing; the live view when
                     capturing) - it does NOT start recording. Capture begins only from the console's
                     own "Start recording" button (or the tray's Start item). OnNavSelectionChanged
                     invokes the open-console callback, then bounces the selection back to the active
                     section so the indicator never parks here. -->
                <ui:NavigationViewItem Content="Record" Tag="Record">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Record24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Sessions" Tag="Sessions"
                                       TargetPageType="{x:Type pages:SessionsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="History24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Matters" Tag="Matters"
                                       TargetPageType="{x:Type pages:MattersPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Folder24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings" Tag="Settings"
                                       TargetPageType="{x:Type pages:SettingsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </DockPanel>
</ui:FluentWindow>
