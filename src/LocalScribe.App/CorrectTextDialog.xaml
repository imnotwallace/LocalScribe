<Window x:Class="LocalScribe.App.CorrectTextDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Correct text" Width="560" SizeToContent="Height" MaxHeight="640"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize">
    <!-- Plain Window by design: a Mica FluentWindow shown from a dialog path can render
         invisible on this machine (see wpfui-fluentwindow-startup-rendering). -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <TextBlock Text="{Binding ValidationMessage}" Foreground="DarkOrange"
                       VerticalAlignment="Center" Margin="0,0,12,0" TextWrapping="Wrap" MaxWidth="280" />
            <Button Content="Save" Click="OnSave" IsDefault="True" MinWidth="80" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" MinWidth="80" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Corrections overlay the transcript; the machine original is always kept and recoverable." />
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Opacity="0.7" FontWeight="SemiBold"
                                       Text="{Binding Stamp, Mode=OneWay, StringFormat='[{0}]'}" />
                            <TextBox Text="{Binding EditedText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="False" Margin="0,4,0,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RevertRequested}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Opacity="0.7" TextWrapping="Wrap" Margin="0,4,0,0">
                                <Run Text="Machine original: " FontStyle="Italic" /><Run Text="{Binding RawText, Mode=OneWay}" />
                            </TextBlock>
                            <CheckBox Content="Revert to machine original"
                                      IsChecked="{Binding RevertRequested}" Margin="0,4,0,0"
                                      Visibility="{Binding IsCorrected, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
