<Page x:Class="LocalScribe.App.Pages.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:LocalScribe.App.ViewModels"
      Title="Sessions">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
    </Page.Resources>
    <Grid Margin="12">
        <DockPanel>
        <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <ui:TextBox Width="220" Margin="0,0,8,8" VerticalAlignment="Center"
                        PlaceholderText="Filter sessions..."
                        Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Width="180" Margin="0,0,8,8" VerticalAlignment="Center"
                      ItemsSource="{Binding MatterFilterOptions}"
                      DisplayMemberPath="Label" SelectedValuePath="Id"
                      SelectedValue="{Binding MatterFilterId}" />
            <CheckBox Content="Show archived" VerticalAlignment="Center" Margin="0,0,8,8"
                      IsChecked="{Binding ShowArchived}" />
            <ui:Button Content="Refresh" Appearance="Secondary" Margin="0,0,8,8"
                       Command="{Binding RefreshCommand}" />
            <TextBlock Text="checking for interrupted sessions..." Margin="4,0,0,0"
                       VerticalAlignment="Center" FontStyle="Italic"
                       Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
        </WrapPanel>
        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" Opacity="0.7"
                   Text="{Binding UnreadableCount, StringFormat='{}{0} unreadable folder(s) skipped'}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding UnreadableCount}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Grid>
        <ui:DataGrid x:Name="SessionsGrid" ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding SelectedRow}"
                     AutoGenerateColumns="False" IsReadOnly="True"
                     CanUserAddRows="False" CanUserSortColumns="True"
                     GridLinesVisibility="None" HeadersVisibility="Column"
                     SelectionMode="Single"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="OnRowDoubleClick">
            <!-- Explicit selection feedback: WPF-UI's thin left accent chip renders
                 inconsistently, so give the selected row a clear full-row tint. The cell
                 background is made transparent when selected so the row tint shows through. -->
            <ui:DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ui:DataGrid.RowStyle>
            <ui:DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ui:DataGrid.CellStyle>
            <ui:DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open"
                              Command="{Binding OpenReadViewCommand}"
                              CommandParameter="{Binding SelectedRow}" />
                    <MenuItem Header="Reveal in Explorer"
                              Command="{Binding RevealInExplorerCommand}"
                              CommandParameter="{Binding SelectedRow}" />
                    <MenuItem Header="Archive / Unarchive"
                              Command="{Binding ToggleArchiveCommand}"
                              CommandParameter="{Binding SelectedRow}" />
                    <MenuItem Header="Split speakers..."
                              Command="{Binding DiariseCommand}"
                              CommandParameter="{Binding SelectedRow}" />
                    <Separator />
                    <MenuItem Header="Delete (to Recycle Bin)..."
                              Command="{Binding DeleteSessionCommand}"
                              CommandParameter="{Binding SelectedRow}"
                              ToolTip="Sends this session's folder to the Recycle Bin. Requires confirmation." />
                </ContextMenu>
            </ui:DataGrid.ContextMenu>
            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="Title" Width="*" MinWidth="160" Binding="{Binding Title}" />
                <DataGridTextColumn Header="App" Width="90" Binding="{Binding AppMedium}" />
                <DataGridTemplateColumn Header="Date" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DateDisplay}" ToolTip="{Binding DateTooltip}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Duration" Width="90" Binding="{Binding DurationDisplay}" />
                <DataGridTemplateColumn Header="Status" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource Chip}"
                                        Visibility="{Binding IsPendingRecovery, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Recovering..." FontStyle="Italic" />
                                </Border>
                                <Border Style="{StaticResource Chip}"
                                        ToolTip="Recovered after an interruption; duration is transcript-derived, not wall-clock"
                                        Visibility="{Binding IsRecovered, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Recovered" />
                                </Border>
                                <Border Style="{StaticResource Chip}"
                                        Visibility="{Binding IsEdited, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Edited" />
                                </Border>
                                <Border Style="{StaticResource Chip}"
                                        Visibility="{Binding IsDiarised, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Diarised" />
                                </Border>
                                <Border Style="{StaticResource Chip}"
                                        ToolTip="{Binding SystemMixTooltip}"
                                        Visibility="{Binding IsSystemMix, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="System mix" />
                                </Border>
                                <Border Style="{StaticResource Chip}"
                                        Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Archived" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </ui:DataGrid.Columns>
        </ui:DataGrid>
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center" TextAlignment="Center"
                       Text="No sessions yet - press Record in the tray to start.">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Rows.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        </DockPanel>
        <!-- Metadata editor detail pane (design 3.3), Stage 5.1 as a slide-in drawer overlaying the
             right of the full-width list; shown only when a session is selected. DetailPane.DataContext
             = MetadataEditorViewModel (set in code-behind); auto-save on commit (TextBoxes bind
             LostFocus, no Save button). The Card inherits the page VM, so its Visibility trigger reads
             SelectedRow directly; the close button clears the grid selection to dismiss it. -->
        <ui:Card x:Name="DetailsDrawer" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                 Width="440" Margin="8,0,0,0" Padding="0">
            <ui:Card.Style>
                <Style TargetType="{x:Type ui:Card}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedRow}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ui:Card.Style>
        <ScrollViewer x:Name="DetailPane" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Appearance="Secondary" Click="OnCloseDetails"
                               ToolTip="Hide details" Padding="8,4" Margin="8,0,0,0" Content="&#x2715;" />
                    <TextBlock DockPanel.Dock="Right" Text="Saved" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Visibility="{Binding SavedIndicator, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="Details" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                </DockPanel>
                <TextBlock Text="{Binding LockHint}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />

                <StackPanel IsEnabled="{Binding IsEditable}">
                    <!-- Session -->
                    <ui:Card Style="{StaticResource SectionCard}" Margin="0,8,0,12">
                        <StackPanel>
                            <TextBlock Text="Session" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="Title" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock Text="Description" Margin="0,12,0,4" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" MinLines="3" TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Classification -->
                    <ui:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Classification" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="Call type" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{x:Static vm:MetadataEditorViewModel.MediumOptions}"
                                      DisplayMemberPath="Display" SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedMedium}" />
                            <DockPanel Margin="0,12,0,4">
                                <CheckBox DockPanel.Dock="Right" Content="Show archived"
                                          IsChecked="{Binding ShowArchivedMatters}" />
                                <TextBlock Text="Matters" />
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding MatterOptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Display}" IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                  Command="{Binding DataContext.ToggleMatterCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>

                    <!-- Participants -->
                    <ui:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Participants" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding Participants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2,0,2">
                                            <ui:Button DockPanel.Dock="Right" Content="Remove" Appearance="Secondary"
                                                       Command="{Binding DataContext.RemoveParticipantCommand,
                                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}" />
                                                <Run Text="{Binding SideDisplay, Mode=OneWay}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <Run Text="{Binding Role, Mode=OneWay}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add existing roster person -->
                            <TextBlock Text="Add from roster" Margin="0,12,0,4" Style="{StaticResource MutedText}" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="Add" Appearance="Primary"
                                           Command="{Binding AddFromRosterCommand}" Margin="8,0,0,0" />
                                <ComboBox ItemsSource="{Binding RosterPicks}" DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedRosterPick}" />
                            </DockPanel>

                            <!-- Add a new person by name -->
                            <TextBlock Text="Add a new person" Margin="0,12,0,4" Style="{StaticResource MutedText}" />
                            <ui:TextBox PlaceholderText="Name"
                                        Text="{Binding NewParticipantName, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="They are a remote participant" Margin="0,6,0,0"
                                      IsChecked="{Binding NewParticipantIsRemote}" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ui:Button Content="Add to this session" Appearance="Secondary"
                                           Command="{Binding AddFreeTextCommand}" Margin="0,0,8,0" />
                                <ui:Button Content="Add to session + roster" Appearance="Primary"
                                           Command="{Binding AddToRosterAndSessionCommand}" />
                            </StackPanel>
                            <DockPanel Margin="0,8,0,0">
                                <ComboBox DockPanel.Dock="Right" MinWidth="160"
                                          ItemsSource="{Binding TaggedMatters}" DisplayMemberPath="Display"
                                          SelectedValuePath="Id" SelectedValue="{Binding RosterTargetMatterId}" />
                                <TextBlock Text="Save new people to matter:" VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- Speakers -->
                    <ui:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Speakers" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="Local speakers" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding LocalCount, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <TextBlock Text="Remote speakers" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding RemoteCount, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                            </UniformGrid>
                            <CheckBox Content="Archived (hidden from the default list)"
                                      IsChecked="{Binding Archived}" Margin="0,12,0,0" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        </ui:Card>
    </Grid>
</Page>
